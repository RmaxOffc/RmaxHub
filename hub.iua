-- Tab switching
local function selectTab(idx)
    for i, btn in ipairs(tabBtns) do
        if i == idx then
            btn.BackgroundTransparency = 0.3
            btn.TextColor3 = Color3.fromRGB(0,255,255)
            contents[i].Visible = true
        else
            btn.BackgroundTransparency = 0.8
            btn.TextColor3 = Color3.fromRGB(200,200,200)
            contents[i].Visible = false
        end
    end
end
for i, btn in ipairs(tabBtns) do
    btn.MouseButton1Click:Connect(function()
        selectTab(i)
    end)
end
selectTab(1)

-- Draggable
local dragStartPos, dragStartMouse
titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragStartPos = mainFrame.Position
        dragStartMouse = input.Position
        local conn
        conn = uis.InputChanged:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseMovement then
                local delta = inp.Position - dragStartMouse
                mainFrame.Position = UDim2.new(dragStartPos.X.Scale, dragStartPos.X.Offset + delta.X, dragStartPos.Y.Scale, dragStartPos.Y.Offset + delta.Y)
            end
        end)
        uis.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                conn:Disconnect()
            end
        end)
    end
end)

-- Minimize
local minimized = false
minimizeBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        for _, c in pairs(contents) do c.Visible = false end
        tabContainer.Visible = false
        mainFrame:TweenSize(UDim2.new(0,500,0,40), "Out", "Quad", 0.2, true)
    else
        mainFrame:TweenSize(UDim2.new(0,500,0,420), "Out", "Quad", 0.2, true)
        wait(0.2)
        tabContainer.Visible = true
        selectTab(1)
    end
end)

-- Show/hide Insert
uis.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.Insert then
        mainFrame.Visible = not mainFrame.Visible
    end
end)

print("DARK CHEAT v2.0 FULL FIXED - Tekan Insert untuk buka/tutup")
