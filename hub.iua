--[[
    DARK CHEAT v2.0 - FULL FIX + BUG REPAIR
    - Perbaikan fly connection leak
    - Fix ESP cleanup ketika player leave
    - Fix god mode persist setelah respawn
    - Fix auto farm boros & glitch
    - Fix crash saat karakter nil
    - Fix slider global input
    - Penambahan error handling
--]]

local player = game.Players.LocalPlayer
local mouse = player:GetMouse()
local runService = game:GetService("RunService")
local uis = game:GetService("UserInputService")

-- ========== SETTINGS ==========
local settings = {
    walkspeed = 100,
    jumppower = 50,
    infinitejump = false,
    fly = false,
    godmode = false,
    killaura = false,
    killaurarange = 30,
    aimbot = false,
    esp = false,
    espdistance = 500,
    espcolor = Color3.fromRGB(0,255,255),
    autofarm = false,
}

-- ========== FLY (FIX CONNECTION) ==========
local bodyVel, bodyGyro, flyConnection
local function startFly()
    stopFly() -- Bersihkan yang lama sebelum memulai baru
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    bodyVel = Instance.new("BodyVelocity")
    bodyGyro = Instance.new("BodyGyro")
    bodyVel.MaxForce = Vector3.new(1e5,1e5,1e5)
    bodyVel.P = 1e4
    bodyGyro.MaxTorque = Vector3.new(1e5,1e5,1e5)
    bodyGyro.P = 1e4
    bodyVel.Parent = char.HumanoidRootPart
    bodyGyro.Parent = char.HumanoidRootPart
    
    flyConnection = runService.RenderStepped:Connect(function()
        if not settings.fly or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
            stopFly()
            return
        end
        local move = Vector3.new()
        if uis:IsKeyDown(Enum.KeyCode.W) then move = move + Vector3.new(0,0,-1) end
        if uis:IsKeyDown(Enum.KeyCode.S) then move = move + Vector3.new(0,0,1) end
        if uis:IsKeyDown(Enum.KeyCode.A) then move = move + Vector3.new(-1,0,0) end
        if uis:IsKeyDown(Enum.KeyCode.D) then move = move + Vector3.new(1,0,0) end
        if uis:IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0,1,0) end
        if uis:IsKeyDown(Enum.KeyCode.LeftControl) then move = move + Vector3.new(0,-1,0) end
        if move.Magnitude > 0 then move = move.Unit else move = Vector3.new(0,0,0) end
        local cam = workspace.CurrentCamera
        local vel = (cam.CFrame.LookVector * move.Z + cam.CFrame.RightVector * move.X + Vector3.new(0,move.Y,0)) * 100
        if bodyVel then bodyVel.Velocity = vel end
        if bodyGyro then
            bodyGyro.CFrame = CFrame.new(player.Character.HumanoidRootPart.Position, player.Character.HumanoidRootPart.Position + cam.CFrame.LookVector)
        end
    end)
end

local function stopFly()
    if flyConnection then flyConnection:Disconnect() flyConnection = nil end
    if bodyVel then bodyVel:Destroy() bodyVel = nil end
    if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
end

-- ========== INFINITE JUMP ==========
uis.JumpRequest:Connect(function()
    if settings.infinitejump then
        local char = player.Character
        if char and char:FindFirstChild("Humanoid") then
            local hum = char.Humanoid
            local state = hum:GetState()
            if hum and (state == Enum.HumanoidStateType.Landed or state == Enum.HumanoidStateType.Freefall) then
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
    end
end)

-- ========== UPDATE SPEED & JUMP ==========
local function updateChar()
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = settings.walkspeed
        char.Humanoid.JumpPower = settings.jumppower
    end
end
player.CharacterAdded:Connect(updateChar)
runService.Heartbeat:Connect(updateChar)

-- ========== GOD MODE (FIX RESPAWN) ==========
local function applyGodMode()
    if not settings.godmode then return end
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        local hum = char.Humanoid
        hum.Health = math.huge
        hum.MaxHealth = math.huge
        hum.BreakJointsOnDeath = false
    end
end
player.CharacterAdded:Connect(applyGodMode) -- Reset god mode setelah respawn

spawn(function()
    while true do
        if settings.godmode then
            applyGodMode()
        end
        wait(0.2)
    end
end)

-- ========== KILL AURA ==========
spawn(function()
    while true do
        if settings.killaura and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local rootPart = player.Character.HumanoidRootPart
            for _, plr in ipairs(game.Players:GetPlayers()) do
                if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Humanoid") then
                    local dist = (plr.Character.HumanoidRootPart.Position - rootPart.Position).Magnitude
                    if dist <= settings.killaurarange then
                        plr.Character.Humanoid.Health = 0
                    end
                end
            end
        end
        wait(0.1)
    end
end)

-- ========== AIMBOT ==========
runService.RenderStepped:Connect(function()
    if settings.aimbot and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local closest, closestDist = nil, 200
        for _, plr in ipairs(game.Players:GetPlayers()) do
            if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local pos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
                if onScreen then
                    local dist = (Vector2.new(mouse.X, mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        closest = plr
                    end
                end
            end
        end
        if closest then
            workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, closest.Character.HumanoidRootPart.Position)
        end
    end
end)

-- ========== ESP (FIX CLEANUP & LEAVE HANDLER) ==========
local espList = {}

-- Hapus ESP untuk player tertentu
local function removeEsp(plr)
    local data = espList[plr]
    if data then
        pcall(function()
            data[1]:Destroy()
            data[2]:Destroy()
        end)
        espList[plr] = nil
    end
end

-- Bersihkan saat player left
game.Players.PlayerRemoving:Connect(function(plr)
    removeEsp(plr)
end)

local function updateEsp()
    if not settings.esp then
        for plr, _ in pairs(espList) do
            removeEsp(plr)
        end
        return
    end
    
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr ~= player then
            -- Jika player sudah tidak ada karakter, hapus ESP
            if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then
                removeEsp(plr)
                continue
            end
            
            if not espList[plr] then
                -- Buat ESP baru
                local highlight = Instance.new("Highlight")
                highlight.FillColor = settings.espcolor
                highlight.OutlineColor = Color3.new(1,1,1)
                highlight.FillTransparency = 0.5
                highlight.Adornee = plr.Character
                highlight.Parent = game.CoreGui
                local text = Drawing.new("Text")
                text.Visible = true
                text.Size = 14
                text.Center = true
                text.Outline = true
                text.Color = Color3.new(1,1,1)
                espList[plr] = {highlight, text}
            else
                -- Update highlight adornee jika karakter berubah
                if espList[plr][1].Adornee ~= plr.Character then
                    espList[plr][1].Adornee = plr.Character
                end
                local dist = (plr.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                if dist <= settings.espdistance then
                    espList[plr][1].Visible = true
                    local pos, on = workspace.CurrentCamera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position + Vector3.new(0,2,0))
                    if on then
                        espList[plr][2].Position = Vector2.new(pos.X, pos.Y - 30)
                        espList[plr][2].Text = plr.Name .. " | " .. math.floor(dist) .. "m"
                        espList[plr][2].Visible = true
                    else
                        espList[plr][2].Visible = false
                    end
                else
                    espList[plr][1].Visible = false
                    espList[plr][2].Visible = false
                end
            end
        end
    end
end

spawn(function()
    while true do
        pcall(updateEsp) -- FIX: error handling
        wait(0.05)
    end
end)

-- ========== AUTO FARM (OPTIMIZED) ==========
local farmConnection
local function startAutoFarm()
    if farmConnection then return end
    farmConnection = runService.Heartbeat:Connect(function()
        if not settings.autofarm or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
            return
        end
        local root = player.Character.HumanoidRootPart
        local nearestObj, nearestDist = nil, 50
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and (obj.Name:lower():find("coin") or obj.Name:lower():find("gem")) then
                local dist = (obj.Position - root.Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearestObj = obj
                end
            end
        end
        if nearestObj then
            root.CFrame = nearestObj.CFrame
        end
    end)
end
local function stopAutoFarm()
    if farmConnection then
        farmConnection:Disconnect()
        farmConnection = nil
    end
end
-- Hubungkan toggle
local function setAutoFarm(v)
    settings.autofarm = v
    if v then startAutoFarm() else stopAutoFarm() end
end

