-- Helper: Toggle dengan emoji
local function addToggle(icon, text, default, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -20, 0, 45)
    frame.BackgroundTransparency = 1
    frame.Parent = contentList
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.7, 0, 1, 0)
    label.Text = icon .. " " .. text
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.TextSize = 15
    label.Parent = frame
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 70, 0, 32)
    btn.Position = UDim2.new(1, -80, 0, 6)
    btn.BackgroundColor3 = default and Color3.fromRGB(0, 200, 255) or Color3.fromRGB(80, 80, 100)
    btn.Text = default and "ON" or "OFF"
    btn.TextColor3 = Color3.new(0,0,0)
    btn.TextSize = 13
    btn.Font = Enum.Font.GothamBold
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(1,0)
    btnCorner.Parent = btn
    btn.Parent = frame
    
    local state = default
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.BackgroundColor3 = state and Color3.fromRGB(0, 200, 255) or Color3.fromRGB(80, 80, 100)
        btn.Text = state and "ON" or "OFF"
        callback(state)
    end)
    return frame
end

-- Helper: Stepper (tombol + / -)
local function addStepper(icon, text, minv, maxv, default, step, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -20, 0, 55)
    frame.BackgroundTransparency = 1
    frame.Parent = contentList
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.5, 0, 1, 0)
    label.Text = icon .. " " .. text
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.TextSize = 15
    label.Parent = frame
    
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0.2, 0, 1, 0)
    valueLabel.Position = UDim2.new(0.5, 0, 0, 0)
    valueLabel.Text = tostring(default)
    valueLabel.TextColor3 = Color3.fromRGB(0, 255, 255)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 16
    valueLabel.Parent = frame
    
    local decBtn = Instance.new("TextButton")
    decBtn.Size = UDim2.new(0, 40, 0, 35)
    decBtn.Position = UDim2.new(0.75, 0, 0, 10)
    decBtn.Text = "-"
    decBtn.TextColor3 = Color3.new(1,1,1)
    decBtn.BackgroundColor3 = Color3.fromRGB(60,60,80)
    decBtn.Font = Enum.Font.GothamBold
    decBtn.TextSize = 20
    local decCorner = Instance.new("UICorner")
    decCorner.CornerRadius = UDim.new(0, 6)
    decCorner.Parent = decBtn
    decBtn.Parent = frame
    
    local incBtn = Instance.new("TextButton")
    incBtn.Size = UDim2.new(0, 40, 0, 35)
    incBtn.Position = UDim2.new(0.85, 0, 0, 10)
    incBtn.Text = "+"
    incBtn.TextColor3 = Color3.new(1,1,1)
    incBtn.BackgroundColor3 = Color3.fromRGB(60,60,80)
    incBtn.Font = Enum.Font.GothamBold
    incBtn.TextSize = 20
    local incCorner = Instance.new("UICorner")
    incCorner.CornerRadius = UDim.new(0, 6)
    incCorner.Parent = incBtn
    incBtn.Parent = frame
    
    local val = default
    local function updateValue(newVal)
        val = math.clamp(newVal, minv, maxv)
        valueLabel.Text = tostring(math.floor(val))
        callback(val)
    end
    
    decBtn.MouseButton1Click:Connect(function() updateValue(val - step) end)
    incBtn.MouseButton1Click:Connect(function() updateValue(val + step) end)
    return frame
end

