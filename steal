-- Fungsi update warna toggle
local function updateToggleUI()
    if teleportEnabled then
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 150, 100)
        toggleButton.Text = "ON"
        teleportButton.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
        teleportButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    else
        toggleButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
        toggleButton.Text = "OFF"
        teleportButton.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        teleportButton.TextColor3 = Color3.fromRGB(150, 150, 180)
    end
end

-- Event Copy
copyButton.MouseButton1Click:Connect(function()
    local pos = getCurrentPosition()
    savedCoordinates = pos
    coordLabel.Text = string.format("📌 Disalin: (%.1f, %.1f, %.1f)", pos.X, pos.Y, pos.Z)
    -- Efek feedback
    copyButton.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
    task.wait(0.15)
    copyButton.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
end)

-- Event Toggle
toggleButton.MouseButton1Click:Connect(function()
    teleportEnabled = not teleportEnabled
    updateToggleUI()
end)

-- Event Teleport
teleportButton.MouseButton1Click:Connect(function()
    if savedCoordinates then
        teleportTo(savedCoordinates)
    else
        coordLabel.Text = "⚠️ Belum ada koordinat! Copy dulu."
        task.wait(1)
        if savedCoordinates then
            coordLabel.Text = string.format("📌 Disalin: (%.1f, %.1f, %.1f)", savedCoordinates.X, savedCoordinates.Y, savedCoordinates.Z)
        else
            coordLabel.Text = "Belum ada koordinat disalin"
        end
    end
end)

-- Update karakter jika respawn
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoidRootPart = character:WaitForChild("HumanoidRootPart")
end)

updateToggleUI()
