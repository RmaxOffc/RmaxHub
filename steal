-- Script ini taruh di StarterGui atau ScreenGui (LocalScript)

local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

-- Variabel
local savedCoordinates = nil
local teleportEnabled = false

-- Fungsi mengambil posisi sekarang
local function getCurrentPosition()
    local pos = humanoidRootPart.Position
    return {X = math.floor(pos.X * 10) / 10, Y = math.floor(pos.Y * 10) / 10, Z = math.floor(pos.Z * 10) / 10}
end

-- Fungsi teleport ke koordinat tertentu
local function teleportTo(coords)
    if coords and teleportEnabled then
        local newPos = Vector3.new(coords.X, coords.Y, coords.Z)
        humanoidRootPart.CFrame = CFrame.new(newPos)
    elseif not teleportEnabled then
        warn("Teleport dimatikan. Nyalakan toggle dulu.")
    end
end

