loadBtn.Position = UDim2.new(0.55, 0, 0, 360)
loadBtn.Text = "Load Config"
loadBtn.BackgroundColor3 = Color3.fromRGB(50,50,70)
loadBtn.Parent = mainFrame

copyBtn.MouseButton1Click:Connect(function()
    local configString = game:GetService("HttpService"):JSONEncode(settings)
    setclipboard(configString)
end)
loadBtn.MouseButton1Click:Connect(function()
    local clipboard = getclipboard()
    local success, loaded = pcall(function()
        return game:GetService("HttpService"):JSONDecode(clipboard)
    end)
    if success and loaded then
        for k,v in pairs(loaded) do
            settings[k] = v
        end
        -- refresh UI (sederhana: print)
        print("Config loaded")
    end
end)

-- Show/Hide Menu dengan Insert
userInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Insert then
        mainFrame.Visible = not mainFrame.Visible
    end
end)

-- Tab switching
local function switchTab(index)
    for i, btn in ipairs(tabButtons) do
        if i == index then
            btn.BackgroundTransparency = 0.5
            btn.TextColor3 = Color3.fromRGB(0,255,255)
            contentFrames[i].Visible = true
        else
            btn.BackgroundTransparency = 0.9
            btn.TextColor3 = Color3.fromRGB(200,200,200)
            contentFrames[i].Visible = false
        end
    end
end
for i, btn in ipairs(tabButtons) do
    btn.MouseButton1Click:Connect(function()
        switchTab(i)
    end)
end
switchTab(1) -- default Movement

