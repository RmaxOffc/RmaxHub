-- ========== FUNGSI UTILITY ==========
local function applyCharacterSettings(character)
    if not character then return end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    if settings.walkspeed then
        humanoid.WalkSpeed = settings.walkspeed
    end
    if settings.jumpPower then
        humanoid.JumpPower = settings.jumpPower
    end
    if settings.infiniteStamina then
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, false)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        -- Stamina tidak ada di Roblox secara default, jadi kita disable fatigue
        humanoid:SetStateEnabled(Enum.HumanoidStateType.GettingUp, false)
    end
end

player.CharacterAdded:Connect(function(character)
    wait(0.5)
    applyCharacterSettings(character)
end)

if player.Character then
    applyCharacterSettings(player.Character)
end

-- ========== FLY ==========
local flyEnabled = false
local flySpeed = 1
local bodyVelocity, bodyGyro

local function startFly()
    local character = player.Character
    if not character then return end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    bodyVelocity = Instance.new("BodyVelocity")
    bodyGyro = Instance.new("BodyGyro")
    bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bodyVelocity.P = 1e4
    bodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    bodyGyro.P = 1e4
    bodyVelocity.Parent = character.HumanoidRootPart
    bodyGyro.Parent = character.HumanoidRootPart
    local flying = true
    local flightConnection
    flightConnection = runService.RenderStepped:Connect(function()
        if not settings.fly or not character or not character.Parent then
            flightConnection:Disconnect()
            if bodyVelocity then bodyVelocity:Destroy() end
            if bodyGyro then bodyGyro:Destroy() end
            return
        end
        local moveDirection = Vector3.new()
        if userInputService:IsKeyDown(Enum.KeyCode.W) then moveDirection = moveDirection + Vector3.new(0,0,-1) end
        if userInputService:IsKeyDown(Enum.KeyCode.S) then moveDirection = moveDirection + Vector3.new(0,0,1) end
        if userInputService:IsKeyDown(Enum.KeyCode.A) then moveDirection = moveDirection + Vector3.new(-1,0,0) end
        if userInputService:IsKeyDown(Enum.KeyCode.D) then moveDirection = moveDirection + Vector3.new(1,0,0) end
        if userInputService:IsKeyDown(Enum.KeyCode.Space) then moveDirection = moveDirection + Vector3.new(0,1,0) end
        if userInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDirection = moveDirection + Vector3.new(0,-1,0) end
        moveDirection = moveDirection.Unit
        local camera = workspace.CurrentCamera
        local forward = camera.CFrame.LookVector
        local right = camera.CFrame.RightVector
        local velocity = (forward * moveDirection.Z + right * moveDirection.X + Vector3.new(0, moveDirection.Y, 0)) * flySpeed * 100
        bodyVelocity.Velocity = velocity
        bodyGyro.CFrame = CFrame.new(character.HumanoidRootPart.Position, character.HumanoidRootPart.Position + camera.CFrame.LookVector)
    end)
end

local function stopFly()
    if bodyVelocity then bodyVelocity:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
end

